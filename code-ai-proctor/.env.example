# AI Observer — Environment Configuration
# Copy to .env and fill in values

# Database: SQLite (local, zero-cost), XAMPP MySQL (local), or Azure SQL (remote)
# For SQLite (recommended for self-hosting):
# DB_CONNECTION_STRING=sqlite:///./ai_observer.db

# For XAMPP MySQL (Local database):
# If running native python:
DB_CONNECTION_STRING=mysql+pymysql://root:@127.0.0.1:3306/ai_observer_db
# If running inside Docker:
# DB_CONNECTION_STRING=mysql+pymysql://root:@host.docker.internal:3306/ai_observer_db

# For Azure SQL (if keeping cloud DB):
# DB_CONNECTION_STRING=Driver={ODBC Driver 18 for SQL Server};Server=...;Database=...;Uid=...;Pwd=...;

# Proctoring
PROCTOR_API_KEY=change-me-to-a-strong-key
PROCTOR_CHEAT_THRESHOLD=0.80
PROCTOR_BATCH_SIZE=8
PROCTOR_DEVICE=cuda
