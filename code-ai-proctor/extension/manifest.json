{
  "manifest_version": 3,
  "name": "AI Proctoring Assistant",
  "version": "1.0",
  "description": "Browser extension for AI-based proctoring and monitoring.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background/worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/monitor.js"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "AI Proctor"
  }
}
